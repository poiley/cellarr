#!/bin/sh
# cellarr is a PRIVATE project — pushing to any remote is forbidden.
# See CLAUDE.md "Rule #1". This hook rejects every push as defense-in-depth.
#
# This is intentional and must not be removed. There is no override flag.
# Local commits, branches, and worktrees are fine; only pushing is blocked.

remote="$1"
url="$2"

echo "------------------------------------------------------------------" >&2
echo "  PUSH BLOCKED: cellarr is a private project and must not be" >&2
echo "  published. Pushing to a remote is disabled by policy." >&2
echo "" >&2
echo "    remote: ${remote:-<none>}" >&2
echo "    url:    ${url:-<none>}" >&2
echo "" >&2
echo "  See CLAUDE.md (Rule #1). Commit locally instead." >&2
echo "------------------------------------------------------------------" >&2

exit 1
