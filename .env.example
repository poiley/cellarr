# cellarr configuration via environment (figment reads CELLARR_* with `__` nesting).
# Copy to `.env` (gitignored) and fill in. Secrets live ONLY in `.env`, never committed.

# --- TheTVDB (TV metadata) ---
# v4 uses a project/licensed API key. Until cellarr ships a self-hosted
# Skyhook-equivalent metadata proxy, the user-supported model applies: a per-user
# subscription PIN is supplied alongside the key at login.
CELLARR_TVDB__API_KEY=
# Optional per-user subscriber PIN (user-supported TheTVDB plan):
CELLARR_TVDB__PIN=

# --- TMDb (movie metadata) ---
CELLARR_TMDB__API_KEY=

# --- Daemon (optional; sensible defaults otherwise) ---
# CELLARR_DATA_DIR=./data
# CELLARR_API__BIND=127.0.0.1
# CELLARR_API__PORT=9494
# CELLARR_API__API_KEY=
