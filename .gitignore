# Rust
/target
**/*.rs.bk
# sqlx offline data is COMMITTED (do not ignore .sqlx)

# cargo-mutants incremental output (do not commit)
mutants.out/
**/mutants.out/
mutants.out.old/
**/mutants.out.old/

# Node / web
node_modules/
web/.next/
web/out/
.DS_Store

# Reference repos: cloned for STUDY ONLY, never shipped, never copied from.
# See docs/agents/legal-and-licensing.md
/reference/

# Local config / secrets / data
*.env
.env.local
/data/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Real deployment config + secrets — NEVER commit (this is a public repo).
# The committed templates are deploy/managed-config.example.yaml and the
# placeholder Secret in deploy/k8s/cellarr.yaml; the real, value-filled copies
# live only here and on the cluster.
# (gitignore has no trailing-comment support — keep patterns on their own lines.)
/deploy/managed-config.yaml
/deploy/k8s/cellarr-secret.yaml
# any k8s Secret manifest with real values, but keep *-secret.example.yaml templates
*-secret.yaml
!*-secret.example.yaml
*.secret.yaml
# local-only manifest overlays
*.local.yaml
secrets/
*.key
*.pem
kubeconfig*

# Per-run scratch dirs for `just dev` (namespaced by RUN_ID) — see docs/16
/.run/

# Editor
.idea/
.vscode/
.shots/

# python bytecode (tests/e2e mock)
__pycache__/
*.pyc

# agent verify screenshots
.run-screenshots/
